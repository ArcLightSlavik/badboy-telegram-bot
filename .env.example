# Required for real Telegram messages.
# Create this with @BotFather, then save it as a GitHub Actions secret.
TELEGRAM_BOT_TOKEN=123456789:replace_me

# Optional: send city alerts to separate channels.
# For a public channel this can be @your_channel_username.
# For a private channel use the numeric -100... chat id.
# The bot must be an admin in each channel.
TELEGRAM_TARGET_CHAT_ID_LVIV=@your_lviv_channel
TELEGRAM_TARGET_CHAT_ID_KYIV=@your_kyiv_channel
TELEGRAM_TARGET_CHAT_ID_DNIPRO=@your_dnipro_channel

# Optional fallback: one generic channel for the cities in FOLLOW_CITIES.
TELEGRAM_TARGET_CHAT_ID=@your_generic_channel

# Optional: which cities to check when there are no direct bot subscribers.
# Supported values: kyiv, lviv, dnipro.
FOLLOW_CITIES=lviv,kyiv,dnipro

# Optional tuning.
TIMEZONE=Europe/Kyiv
MAX_PAGES=5
NOTIFY_ON_FIRST_RUN=false
