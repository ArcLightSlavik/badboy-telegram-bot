# Required for real Telegram messages.
# Create this with @BotFather, then save it as a GitHub Actions secret.
TELEGRAM_BOT_TOKEN=123456789:replace_me

# Optional: send Lviv alerts to one or more channels.
# For a public channel this can be @your_channel_username.
# For a private channel use the numeric -100... chat id.
# The bot must be an admin in each channel.
TELEGRAM_TARGET_CHAT_ID_LVIV=@your_lviv_channel,@your_second_lviv_channel

# Optional fallback channel list. Usually you can leave this unset.
# TELEGRAM_TARGET_CHAT_ID=@your_generic_channel

# Optional tuning.
TIMEZONE=Europe/Kyiv
MAX_PAGES=5
NOTIFY_ON_FIRST_RUN=false
